# ─── OpenClaw Docker Configuration ───────────────────────────────────
# Fill in the values below before running: ./setup.sh

# ─── Image ───────────────────────────────────────────────────────────
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# ─── Gateway ─────────────────────────────────────────────────────────
# Auto-generated by setup.sh if left as placeholder
OPENCLAW_GATEWAY_TOKEN=321b2211df004e4f7da54bbab15df54d5a5a7b968b33a2a13bf28ab5ad62f9aa
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# ─── Anthropic / Claude API Key (REQUIRED) ──────────────────────────
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Telegram Bot Token (REQUIRED) ──────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ─── Optional ────────────────────────────────────────────────────────
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=
